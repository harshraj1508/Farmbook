generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
model farms {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  location    String?   @db.VarChar(255)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  total_bigha Decimal?  @db.Decimal(10, 2)
}

model users {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(100)
  email         String    @unique @db.VarChar(255)
  password_hash String    @db.VarChar(255)
  role          String    @db.VarChar(20)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
}

model plots {

  id          Int       @id @default(autoincrement())
  farm_id      Int

  name        String    @db.VarChar(100)

  area_bigha  Decimal   @db.Decimal(10,2)

  label_color String?   @db.VarChar(50)

  status      String    @db.VarChar(20)

}

model plantings {
  id                Int      @id @default(autoincrement())
  plot_id           Int
  crop_id           Int
  sow_date          DateTime
  plant_count       Int
  expected_harvest  DateTime
  status            String

  @@map("plantings")
}

model crop {
  id        Int    @id @default(autoincrement())
  name      String @db.VarChar(100)
  variety   String @db.VarChar(100)
  protocol  Json

  @@map("crop")
}